VM_USERNAME=eblan
PORT=9213
DBNAME=postgres

PSQL="psql -p $PORT -d $DBNAME"

CLUSTER_FOLDER="$HOME/yhv53"

DATA_FOLDER="$CLUSTER_FOLDER/data"
LOG_FILE="$CLUSTER_FOLDER/postgresql.log"

GOOSE_DRIVER=postgres
DB_DSN="postgresql://${VM_USERNAME}@localhost:5432/${DBNAME}?sslmode=disable"
GOOSE_ENV="GOOSE_DRIVER=$(GOOSE_DRIVER) GOOSE_DBSTRING=$(DB_DSN)"

GOOSE_ARGS=-dir ${TPC_C_MIGRATIONS_FOLDER}
